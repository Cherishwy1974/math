                    <h2 style="color: #333; font-size: 1.5rem; margin: 0; display: flex; align-items: center;">
                        <i class="fas fa-book" style="margin-right: 8px; color: #555;"></i> 重要知识点
                    </h2>
                    <div class="circle-nav" style="display: flex; gap: 8px;">
                        <span class="circle-num active" data-slide="0" onclick="goToSlide(0)"
                            style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: #f0f0f0; color: #333; border-radius: 50%; font-weight: bold; cursor: pointer;">基</span>
                        <span class="circle-num" data-slide="1" onclick="goToSlide(1)"
                            style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: #f0f0f0; color: #333; border-radius: 50%; font-weight: bold; cursor: pointer;">一</span>
                        <span class="circle-num" data-slide="2" onclick="goToSlide(2)"
                            style="width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; background: #f0f0f0; color: #333; border-radius: 50%; font-weight: bold; cursor: pointer;">二</span>
                    </div>
