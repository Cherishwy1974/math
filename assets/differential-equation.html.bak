<!DOCTYPE html>
<html lang="zh-CN">

<head>
    <meta charset="UTF-8">
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>微分方程知识点整理</title>

    <!-- 加载指示器样式 -->
    <style>
        /* 核心色彩变量 */
        :root {
            --primary-color: #2c4cc3;
            --secondary-color: #3498db;
            --accent-color: #e74c3c;
            --bg-color: #f8f9fa;
            --text-color: #2c3e50;
            --light-gray: #f5f7fa;
            --dark-gray: #343a40;
            --border-color: #e2e8f0;
            --card-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            --border-radius: 8px;
            --transition-speed: 0.3s;
        }

        /* 基础样式 */
        body {
            font-family: 'Microsoft YaHei', Arial, sans-serif;
            line-height: 1.5;
            color: #333;
            background-color: #f8f9fa;
            margin: 0;
            padding: 20px;
        }

        /* 全局样式重置 - 确保导航栏不固定 */
        header, .navbar, .page-header, nav, .navbar-fixed-top {
            position: static !important;
            top: auto !important;
            bottom: auto !important;
            left: auto !important;
            right: auto !important;
            z-index: 1 !important;
            transform: none !important;
        }
        
        /* 强制习题标签显示在一行 */
        .exercise-meta {
            display: flex !important;
            flex-direction: row !important;
            flex-wrap: nowrap !important;
            white-space: nowrap !important;
            overflow-x: auto !important;
            width: auto !important;
            gap: 3px !important;
            margin: 0 !important;
            padding: 0 !important;
            max-width: 100% !important;
            scrollbar-width: none !important; /* Firefox */
        }
        
        /* 隐藏滚动条但保留滚动功能 */
        .exercise-meta::-webkit-scrollbar {
            display: none !important;
        }
        
        .exercise-type, .exercise-difficulty, .exercise-category, .exercise-method {
            display: inline-block !important;
            padding: 2px 5px !important;
            margin-right: 3px !important;
            font-size: 0.75rem !important;
            white-space: nowrap !important;
            flex-shrink: 0 !important;
        }

        /* MathJax样式 */
        .MathJax,
        .MathJax_Display {
            text-align: left !important;
        }

        .mjx-chtml.MJXc-display {
            text-align: left !important;
            margin: 0.5em 0 !important;
        }

        /* 简化卡片阴影效果 */
        .exercise-item {
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08);
            transition: box-shadow 0.2s;
        }

        .exercise-item:hover {
            box-shadow: 0 3px 8px rgba(0, 0, 0, 0.12);
        }
        
        .loading-indicator {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 3px;
            background: transparent;
            z-index: 9999;
        }

        .loading-bar {
            height: 100%;
            width: 0;
            background: #2c4cc3;
            transition: width 0.3s ease;
        }

        /* 移除按钮点击效果，只保留颜色变化 */
        .filter-btn,
        .solution-toggle {
            position: relative;
            transition: background-color 0.2s ease;
        }

        .filter-btn.active {
            background-color: var(--primary-color);
            color: white;
        }




        .inline-slide {
            background: white;
            border-radius: 8px;
            padding: 20px;
            margin-bottom: 20px;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .inline-exercise-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
            padding-bottom: 15px;
            border-bottom: 1px solid #e2e8f0;
        }

        .inline-exercise-title-wrapper {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .inline-exercise-number {
            background: #2c4cc3;
            color: white;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.1rem;
        }

        .inline-exercise-title {
            font-size: 1.5rem;
            margin: 0;
            color: #2c3e50;
        }

        .inline-exercise-meta {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
        }

        .inline-exercise-tag {
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            color: white;
            display: flex;
            align-items: center;
        }

        .inline-exercise-tag i {
            margin-right: 6px;
        }

        .inline-exercise-tag.type {
            background: #3498db;
        }

        .inline-exercise-tag.difficulty {
            background: #e74c3c;
        }

        .inline-exercise-tag.category {
            background: #9b59b6;
        }

        .inline-exercise-tag.method {
            background: #34495e;
        }

        .inline-exercise-tag.difficulty.easy {
            background: #2ecc71;
        }

        .inline-exercise-tag.difficulty.medium {
            background: #f39c12;
        }

        .inline-exercise-tag.difficulty.hard {
            background: #e74c3c;
        }

        .inline-exercise-question {
            font-size: 1.2rem;
            margin-bottom: 30px;
            padding: 20px;
            background: #f5f7fa;
            border-radius: 8px;
            box-shadow: 0 2px 6px rgba(0, 0, 0, 0.1);
        }

        .inline-solution-section {
            position: relative;
        }

        .inline-toggle-solution-btn {
            padding: 8px 16px;
            background: #2c4cc3;
            color: white;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            font-size: 14px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 6px;
            transition: background 0.3s;
        }

        .inline-toggle-solution-btn:hover {
            background: #1a3cb3;
        }

        .inline-solution-content {
            background: white;
            border-radius: 8px;
            padding: 0;
            overflow: hidden;
            max-height: 0;
            opacity: 0;
            transition: max-height 0.5s, opacity 0.5s, padding 0.5s;
            visibility: hidden;
        }

        .inline-solution-content.user-clicked {
            max-height: 2000px;
            padding: 20px;
            opacity: 1;
            visibility: visible;
            margin-bottom: 20px;
            border: 1px solid #e2e8f0;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
        }

        .inline-solution-text {
            white-space: pre-wrap;
            display: inline;
        }

        .solution-paragraph {
            margin-bottom: 0.8em;
            animation: fadeIn 0.3s ease;
        }

        .fs-solution-line {
            opacity: 0;
            transform: translateY(10px);
            animation: none;
            margin-bottom: 1em;
            padding: 0.5em 1em;
            border-radius: 8px;
            background: rgba(255, 255, 255, 0.8);
            transition: all 0.3s ease;
        }

        .fs-solution-line:last-child {
            margin-bottom: 0;
        }

        .fs-ripple {
            position: absolute;
            border-radius: 50%;
            background-color: rgba(44, 76, 195, 0.3);
            transform: translate(-50%, -50%) scale(0);
            pointer-events: none;
            z-index: 9999;
            animation: ripple 0.6s ease-out;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeOut {
            from {
                opacity: 1;
                transform: translateY(0);
            }

            to {
                opacity: 0;
                transform: translateY(10px);
            }
        }

        @keyframes ripple {
            to {
                transform: translate(-50%, -50%) scale(3);
                opacity: 0;
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .inline-explanation,
        .inline-answer {
            margin-bottom: 25px;
        }

        .inline-explanation h4,
        .inline-answer h4 {
            color: #2c4cc3;
            display: flex;
            align-items: center;
            margin-top: 0;
            margin-bottom: 10px;
            font-size: 1.2rem;
            padding-left: 10px;
            border-left: 4px solid #2c4cc3;
        }

        .inline-explanation h4 i,
        .inline-answer h4 i {
            margin-right: 8px;
        }

        /* 添加视觉反馈样式 */
        .inline-solution-content.user-clicked {
            cursor: pointer;
            position: relative;
            z-index: 100;
        }

        .inline-solution-content.user-clicked:hover {
            background-color: rgba(52, 152, 219, 0.05);
        }

        .inline-solution-content.user-clicked:active {
            background-color: rgba(52, 152, 219, 0.1);
        }

        /* DeepSeek AI相关样式 */
        :root {
            --deepseek-primary: #3498db;
            --deepseek-secondary: #2980b9;
            --deepseek-accent: #1abc9c;
        }

        /* AI分析按钮样式 */
        .ai-analysis-btn {
            display: inline-flex;
            align-items: center;
            padding: 6px 14px;
            background: var(--deepseek-primary);
            color: white;
            border: none;
            border-radius: 20px;
            cursor: pointer;
            font-size: 13px;
            font-weight: 500;
            margin-left: 5px;
            transition: background-color 0.3s ease;
        }

        .ai-analysis-btn:hover {
            background-color: var(--deepseek-secondary);
        }

        .ai-analysis-btn i {
            margin-right: 6px;
        }

        /* Slideshow styles */
        .slides-container {
            position: relative;
            width: 100%;
            min-height: 520px;
            margin-bottom: 10px;
        }

        .slide {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            opacity: 0;
            pointer-events: none;
            transition: opacity var(--transition-speed) ease, transform var(--transition-speed) ease;
            transform: translateY(30px);
            z-index: 5;
        }

        .slide.active {
            opacity: 1;
            pointer-events: auto;
            transform: translateY(0);
            z-index: 10;
        }

        .slide-card {
            background: white;
            border-radius: 15px;
            padding: 40px 30px 30px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1);
            position: relative;
            width: 90%;
            margin: 0 auto;
            max-width: 1000px;
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            cursor: pointer;
        }

        .slide-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.15);
        }

        .slide-number {
            position: absolute;
            top: -20px;
            left: -15px;
            width: 44px;
            height: 44px;
            background: var(--primary-color);
            color: white;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            font-size: 1.3rem;
            box-shadow: 0 4px 10px rgba(44, 76, 195, 0.3);
            z-index: 5;
            border: 3px solid white;
        }

        .slide-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            padding-bottom: 10px;
            border-bottom: 2px solid rgba(44, 76, 195, 0.2);
            position: relative;
        }

        .slide-title {
            font-size: 1.3rem;
            color: var(--primary-color);
            position: relative;
            margin: 0;
            padding-left: 8px;
            flex: 1;
        }

        .slide-content {
            position: relative;
            z-index: 1;
            font-size: 0.95rem;
        }

        .circle-nav {
            display: flex;
            gap: 12px;
            background: rgba(255, 255, 255, 0.9);
            padding: 10px 20px;
            border-radius: 30px;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.1);
        }

        .circle-num {
            width: 36px;
            height: 36px;
            border-radius: 50%;
            background: #e2e8f0;
            color: #2c3e50;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            font-size: 1rem;
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.1);
        }

        .circle-num:hover {
            transform: scale(1.1);
            background: #d1e0f6;
        }

        .circle-num.active {
            background: var(--primary-color);
            color: white;
            transform: scale(1.15);
            box-shadow: 0 4px 8px rgba(44, 76, 195, 0.3);
        }

        @media (max-width: 1100px) {
            .slide-card {
                padding: 30px 25px 25px;
                width: 95%;
            }

            .slide-title {
                font-size: 1.5rem;
                margin-bottom: 16px;
            }

            .slide-content {
                font-size: 0.9rem;
            }
        }

        /* 筛选器和题目定位器样式 */
        .filter-section {
            margin-bottom: 25px;
            padding: 15px 20px;
            background: white;
            border-radius: var(--border-radius);
            box-shadow: var(--card-shadow);
        }

        .filter-subtitle {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            font-size: 1.1rem;
            color: var(--primary-color);
        }

        .filter-subtitle i {
            margin-right: 10px;
        }

        .locator-section {
            margin-bottom: 20px;
            padding: 15px 20px;
            background: white;
            border-radius: var(--border-radius);
            box-shadow: var(--card-shadow);
        }

        .locator-title {
            display: flex;
            align-items: center;
            margin-bottom: 12px;
        }

        .locator-title i {
            margin-right: 10px;
            color: var(--primary-color);
        }

        .locator-title h4 {
            margin: 0;
            font-size: 1.1rem;
            color: var(--primary-color);
        }

        .locator-input-container {
            display: flex;
            gap: 10px;
        }

        .problem-number-input {
            flex: 1;
            padding: 10px 15px;
            border: 1px solid #ddd;
            border-radius: 6px;
            font-size: 16px;
        }

        .locate-problem-btn {
            padding: 10px 20px;
            background: var(--primary-color);
            color: white;
            border: none;
            border-radius: 6px;
            cursor: pointer;
            transition: background-color 0.3s;
            display: flex;
            align-items: center;
        }

        .locate-problem-btn:hover {
            background-color: #1e3a8a;
        }

        .locate-problem-btn i {
            margin-right: 8px;
        }

        /* 高亮样式 */
        .problem-highlight {
            animation: highlight-pulse 2s;
        }

        @keyframes highlight-pulse {
            0% {
                box-shadow: 0 0 0 0 rgba(44, 76, 195, 0.7);
            }

            70% {
                box-shadow: 0 0 0 15px rgba(44, 76, 195, 0);
            }

            100% {
                box-shadow: 0 0 0 0 rgba(44, 76, 195, 0);
            }
        }

        .filter-title {
            margin-bottom: 15px;
            display: flex;
            align-items: center;
        }

        .filter-title i {
            margin-right: 10px;
            color: var(--primary-color);
        }

        .filter-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .filter-btn {
            padding: 8px 15px;
            background: var(--light-gray);
            border: none;
            border-radius: 20px;
            cursor: pointer;
            transition: all var(--transition-speed);
            font-size: 0.9rem;
            display: flex;
            align-items: center;
        }

        .filter-btn i {
            margin-right: 5px;
        }

        /* 全局DeepSeek查询框 */
        .global-deepseek-container {
            background: white;
            padding: 20px;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
            margin-bottom: 30px;
        }

        .global-deepseek-title {
            display: flex;
            align-items: center;
            margin-bottom: 15px;
            color: var(--deepseek-primary);
        }

        .global-deepseek-title i {
            margin-right: 10px;
            font-size: 1.5rem;
        }

        .global-deepseek-title h3 {
            margin: 0;
        }

        .global-deepseek-input-container {
            display: flex;
            gap: 10px;
        }

        .global-deepseek-input {
            flex: 1;
            padding: 12px 15px;
            border: 2px solid #ddd;
            border-radius: 8px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        .global-deepseek-input:focus {
            border-color: var(--deepseek-primary);
            outline: none;
        }

        .global-deepseek-btn {
            padding: 10px 20px;
            background: var(--deepseek-primary);
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-weight: 500;
            transition: background-color 0.3s;
            display: flex;
            align-items: center;
        }

        .global-deepseek-btn:hover {
            background-color: var(--deepseek-secondary);
        }

        .global-deepseek-btn i {
            margin-right: 8px;
        }

        /* DeepSeek AI Chat模态框样式 */
        .deepseek-modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 2000;
            overflow: auto;
            animation: fadeIn 0.3s;
        }

        .deepseek-modal.show {
            display: flex;
            justify-content: center;
            align-items: center;
        }

        .deepseek-modal-content {
            background-color: white;
            width: 800px;
            max-width: 90%;
            height: 80vh;
            border-radius: 12px;
            overflow: hidden;
            display: flex;
            flex-direction: column;
            position: relative;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            animation: slideUp 0.4s;
        }

        .deepseek-modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 20px;
            background: var(--deepseek-primary);
            color: white;
        }

        .deepseek-modal-title {
            font-size: 1.2rem;
            font-weight: bold;
            margin: 0;
        }

        .deepseek-modal-close {
            background: transparent;
            border: none;
            color: white;
            font-size: 1.5rem;
            cursor: pointer;
            padding: 0;
            transition: transform 0.3s;
        }

        .deepseek-modal-close:hover {
            transform: scale(1.1);
        }

        .deepseek-modal-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 20px;
            overflow: hidden;
        }

        .deepseek-chat-container {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            background: #f8f9fa;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .deepseek-chat-message {
            margin-bottom: 15px;
            max-width: 90%;
        }

        .deepseek-chat-user {
            margin-left: auto;
            background: #dcf8c6;
            padding: 10px 15px;
            border-radius: 18px 18px 0 18px;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
        }

        .deepseek-chat-ai {
            margin-right: auto;
            background: white;
            padding: 10px 15px;
            border-radius: 18px 18px 18px 0;
            box-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
            border-left: 3px solid var(--deepseek-primary);
        }

        .deepseek-chat-input-container {
            display: flex;
            gap: 10px;
        }

        .deepseek-chat-input {
            flex: 1;
            padding: 12px;
            border: 2px solid #ddd;
            border-radius: 24px;
            font-size: 16px;
            transition: border-color 0.3s;
        }

        .deepseek-chat-input:focus {
            border-color: var(--deepseek-primary);
            outline: none;
        }

        .deepseek-chat-send {
            padding: 10px 20px;
            background: var(--deepseek-primary);
            color: white;
            border: none;
            border-radius: 24px;
            cursor: pointer;
            font-weight: bold;
            transition: background-color 0.3s;
        }

        .deepseek-chat-send:hover {
            background-color: var(--deepseek-secondary);
        }

        /* 加载动画 */
        @keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        @keyframes slideUp {
            from {
                transform: translateY(30px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            border-top-color: #fff;
            animation: spin 1s ease-in-out infinite;
            margin-right: 10px;
        }

        @keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        /* 响应式调整 */
        @media (max-width: 768px) {
            .deepseek-modal-content {
                height: 90vh;
                width: 95%;
            }

            .global-deepseek-input-container {
                flex-direction: column;
            }
        }

        /* 移动端响应式设计 */
        /* 移动端基础优化 */
        @media (max-width: 768px) {

            /* 基础字体和间距 */
            body {
                font-size: 16px;
                padding: 10px;
                line-height: 1.6;
            }

            .container {
                padding: 10px;
                max-width: 100%;
            }

            /* 导航栏移动端优化 */
            .navbar {
                padding: 10px 0;
            }

            .navbar-container {
                flex-direction: column;
                align-items: flex-start;
                padding: 0 15px;
            }

            .navbar-brand {
                font-size: 1.3rem;
                margin-bottom: 8px;
            }

            .navbar-subtitle {
                font-size: 0.8rem;
                margin-bottom: 10px;
            }

            .navbar-nav {
                flex-direction: row;
                width: 100%;
                justify-content: space-around;
                margin-top: 10px;
            }

            .nav-item {
                margin: 0 5px;
            }

            .nav-link {
                padding: 8px 12px;
                font-size: 0.9rem;
            }

            /* 页面标题移动端优化 */
            .page-header h1 {
                font-size: 1.8rem;
                margin-bottom: 8px;
            }

            /* DeepSeek AI助手移动端优化 */
            .global-deepseek-container {
                margin: 5px 0;
                padding: 12px;
            }

            .global-deepseek-title h3 {
                font-size: 1.1rem;
            }

            .global-deepseek-input-container {
                flex-direction: column;
                gap: 8px;
            }

            .global-deepseek-input,
            .deepseek-api-key {
                padding: 12px;
                font-size: 16px;
                /* 防止iOS缩放 */
                border-radius: 8px;
            }

            .global-deepseek-btn {
                padding: 12px 20px;
                font-size: 16px;
                width: 100%;
                justify-content: center;
            }

            /* 知识点幻灯片移动端优化 */
            .slides-container {
                min-height: 400px;
                margin-bottom: 15px;
            }

            .slide-card {
                padding: 20px 15px;
                width: 95%;
                margin: 0 auto;
            }

            .slide-title {
                font-size: 1.2rem;
                margin-bottom: 12px;
            }

            .slide-content {
                font-size: 0.9rem;
                line-height: 1.5;
            }

            .circle-nav {
                gap: 8px;
                padding: 8px 15px;
                margin-left: 0 !important;
                margin-top: 10px;
                justify-content: center;
            }

            .circle-num {
                width: 32px;
                height: 32px;
                font-size: 0.9rem;
                min-width: 32px;
                /* 确保触摸目标大小 */
                min-height: 32px;
            }

            /* 筛选器移动端优化 */
            .filter-section {
                margin-bottom: 15px;
                padding: 12px;
            }

            .filter-container {
                display: grid;
                grid-template-columns: repeat(2, 1fr);
                gap: 8px;
            }

            .filter-btn {
                padding: 12px 10px;
                font-size: 0.85rem;
                text-align: center;
                min-height: 44px;
                /* 确保触摸目标大小 */
                display: flex;
                align-items: center;
                justify-content: center;
                flex-wrap: wrap;
            }

            .filter-btn i {
                margin-right: 4px;
            }

            .filter-btn .count {
                font-size: 0.8rem;
                margin-left: 4px;
            }

            /* 题目定位器移动端优化 */
            .locator-section {
                margin-bottom: 15px;
                padding: 12px;
            }

            .locator-input-container {
                flex-direction: column;
                gap: 8px;
            }

            .problem-number-input {
                font-size: 16px;
                /* 防止iOS缩放 */
                padding: 12px;
            }

            .locate-problem-btn {
                padding: 12px 20px;
                width: 100%;
                justify-content: center;
                min-height: 44px;
            }

            /* 习题项目移动端优化 */
            .exercise-item {
                margin-bottom: 12px;
                border-radius: 8px;
            }

            .exercise-header {
                display: flex !important;
                flex-direction: row !important;
                align-items: center !important;
                padding: 10px !important;
                flex-wrap: nowrap !important;
                justify-content: space-between !important;
                overflow: hidden !important;
            }

            .exercise-title-wrapper {
                width: auto;
                margin-bottom: 0;
                margin-right: 10px;
            }

            .exercise-title {
                font-size: 1.1rem;
            }

            .exercise-meta {
                display: inline-flex !important;
                align-items: center !important;
                gap: 3px !important;
                flex-wrap: nowrap !important;
                width: auto !important;
                white-space: nowrap !important;
                overflow: visible !important;
                flex-direction: row !important;
                margin: 0 !important;
                padding: 0 !important;
            }

            .exercise-type,
            .exercise-difficulty,
            .exercise-category,
            .exercise-method {
                padding: 4px 8px;
                font-size: 0.8rem;
                flex-shrink: 0;
                margin-right: 3px;
                display: inline-block;
                white-space: nowrap;
            }

            .exercise-content {
                padding: 12px 15px;
            }

            .exercise-question {
                font-size: 1rem;
                line-height: 1.5;
                padding: 12px;
            }

            /* 按钮移动端优化 */
            .solution-toggle,
            .ai-analysis-btn,
            .fs-view-btn {
                padding: 10px 16px;
                font-size: 14px;
                margin: 8px 5px 8px 0;
                min-height: 40px;
                border-radius: 20px;
            }

            /* 解析内容移动端优化 */
            .solution-content {
                margin-top: 10px;
                padding: 12px;
                border-radius: 8px;
            }

            .explanation-content {
                padding: 12px;
                font-size: 0.95rem;
                line-height: 1.5;
            }

            /* DeepSeek模态框移动端优化 */
            .deepseek-modal-content {
                width: 95%;
                height: 90vh;
                margin: 5vh auto;
                border-radius: 8px;
            }

            .deepseek-modal-header {
                padding: 12px 15px;
            }

            .deepseek-modal-title {
                font-size: 1.1rem;
            }

            .deepseek-modal-body {
                padding: 15px;
            }

            .deepseek-chat-container {
                margin-bottom: 12px;
            }

            .deepseek-chat-message {
                margin-bottom: 12px;
                max-width: 95%;
                font-size: 0.95rem;
            }

            .deepseek-chat-input-container {
                flex-direction: column;
                gap: 8px;
            }

            .deepseek-chat-input {
                font-size: 16px;
                /* 防止iOS缩放 */
                padding: 12px;
                border-radius: 8px;
            }

            .deepseek-chat-send {
                padding: 12px 20px;
                width: 100%;
                justify-content: center;
                border-radius: 8px;
            }

            /* 全屏查看移动端优化 */
            .fs-content {
                padding: 15px;
            }

            .fs-problem {
                padding: 15px;
            }

            .fs-problem-title {
                font-size: 1.2rem;
            }

            .fs-question {
                font-size: 1rem;
                padding: 12px;
            }

            .fs-footer {
                flex-direction: column;
                gap: 10px;
                padding: 12px 15px;
            }

            #fs-prev-btn,
            #fs-next-btn {
                width: 100%;
                padding: 12px 20px;
                margin: 0;
                justify-content: center;
            }

            #fs-info {
                text-align: center;
                order: -1;
                /* 移到顶部 */
                margin-bottom: 10px;
            }
        }

        /* 更小屏幕优化 (手机竖屏) */
        @media (max-width: 480px) {
            body {
                padding: 5px;
                font-size: 15px;
            }

            .container {
                padding: 5px;
            }

            .slide-card {
                padding: 15px 10px;
            }

            .filter-container {
                grid-template-columns: 1fr;
            }

            .exercise-header {
                padding: 10px 12px;
            }

            .exercise-content {
                padding: 10px 12px;
            }

            .circle-nav {
                gap: 6px;
                padding: 6px 12px;
            }

            .circle-num {
                width: 28px;
                height: 28px;
                font-size: 0.8rem;
            }
        }

        /* 触摸设备优化 */
        @media (hover: none) and (pointer: coarse) {

            /* 增大所有可点击元素的触摸目标 */
            .filter-btn,
            .solution-toggle,
            .ai-analysis-btn,
            .fs-view-btn,
            .locate-problem-btn,
            .global-deepseek-btn,
            .circle-num {
                min-height: 44px;
                min-width: 44px;
            }

            /* 移除hover效果，避免粘滞 */
            .slide-card:hover,
            .exercise-item:hover {
                transform: none;
                box-shadow: inherit;
            }
        }

        /* 移动设备特定样式 */
        .mobile-device .slide-card:hover {
            transform: none !important;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
        }

        .mobile-device .exercise-item:hover {
            box-shadow: 0 2px 5px rgba(0, 0, 0, 0.08) !important;
        }

        /* 防止iOS缩放 */
        input[type="text"],
        input[type="number"],
        input[type="password"],
        textarea {
            font-size: 16px !important;
        }
