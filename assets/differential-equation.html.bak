            <!-- 简化的习题部分 -->
            <section id="exercises" class="exercise-section" style="margin-top: 30px;">
                <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 15px;">
                    <h2 style="color: #333; font-size: 1.5rem; margin: 0; display: flex; align-items: center;">
                        <i class="fas fa-pencil-alt" style="margin-right: 8px; color: #555;"></i> 练习题
                    </h2>
                </div>

                <!-- 分类筛选 -->
                <div class="filter-section" style="margin-bottom: 15px; border: none; padding: 0;">
                    <div class="filter-container" style="margin-top: 10px;">
                        <button class="filter-btn active" data-filter="all">
                            <i class="fas fa-list"></i> 全部题目 <span class="count">(0)</span>
                        </button>
                        <button class="filter-btn" data-filter="concepts">
                            <i class="fas fa-book"></i> 基本概念 <span class="count">(0)</span>
                        </button>
                        <button class="filter-btn" data-filter="separable">
                            <i class="fas fa-calculator"></i> 可分离变量 <span class="count">(0)</span>
                        </button>
                        <button class="filter-btn" data-filter="homogeneous">
